<Window x:Class="YouTubeTool.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:YouTubeTool.Converters"
        Title="YouTubeTool" Height="650" Width="1050" MinHeight="400" MinWidth="700"
        Background="#1E1E1E">
    <Window.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
        <conv:TestResultColorConverter x:Key="TestResultColorConverter"/>
        <conv:IsShortToViewboxConverter x:Key="IsShortToViewbox"/>

        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Background" Value="#0E639C"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="3" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1177BB"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#444"/>
                                <Setter Property="Foreground" Value="#888"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource ActionButton}">
            <Setter Property="Background" Value="#007ACC"/>
        </Style>

        <Style x:Key="DangerButton" TargetType="Button">
            <Setter Property="Background" Value="#5A1A1A"/>
            <Setter Property="Foreground" Value="#FF6B6B"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="3" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#7A2222"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#444"/>
                                <Setter Property="Foreground" Value="#888"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="WatchedButton" TargetType="Button">
            <Setter Property="Background" Value="#1A3A1A"/>
            <Setter Property="Foreground" Value="#6BCB6B"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="3" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#225522"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SkipButton" TargetType="Button">
            <Setter Property="Background" Value="#2A2A1A"/>
            <Setter Property="Foreground" Value="#C8C86B"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="3" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#3A3A22"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="StarButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#555"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="3" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="#FFD700"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ListBox">
            <Setter Property="Background" Value="#1E1E1E"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="#DDD"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#3C3C3C"/>
            <Setter Property="Foreground" Value="#DDD"/>
            <Setter Property="BorderBrush" Value="#555"/>
            <Setter Property="CaretBrush" Value="White"/>
            <Setter Property="Padding" Value="4,2"/>
        </Style>
    </Window.Resources>

    <DockPanel>
        <!-- Status bar -->
        <StatusBar DockPanel.Dock="Bottom" Background="#007ACC" Foreground="White">
            <StatusBarItem>
                <TextBox Text="{Binding StatusMessage, Mode=OneWay}"
                         IsReadOnly="True" BorderThickness="0" Background="Transparent"
                         Foreground="White" CaretBrush="White" SelectionBrush="#44FFFFFF"
                         FontSize="{x:Static SystemFonts.MessageFontSize}"/>
            </StatusBarItem>
            <StatusBarItem HorizontalAlignment="Right">
                <ProgressBar Width="120" Height="10" IsIndeterminate="True"
                             Foreground="White"
                             Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}"/>
            </StatusBarItem>
        </StatusBar>

        <!-- Main 3-panel layout -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200" MinWidth="140"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="230" MinWidth="160"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="*" MinWidth="280"/>
            </Grid.ColumnDefinitions>

            <!-- PANEL 1: Lists -->
            <DockPanel Grid.Column="0">
                <Border DockPanel.Dock="Top" Background="#252526" Padding="10,8">
                    <TextBlock Text="LISTS" FontWeight="Bold" FontSize="11" Foreground="#888"/>
                </Border>

                <Border DockPanel.Dock="Bottom" Background="#252526" Padding="6">
                    <StackPanel>
                        <Button Content="+ Add List" Margin="0,0,0,4" Padding="6,4"
                                Command="{Binding AddListCommand}"
                                Style="{StaticResource ActionButton}"/>
                        <Button Content="Delete List" Margin="0,0,0,4" Padding="6,4"
                                Command="{Binding DeleteListCommand}"
                                Style="{StaticResource DangerButton}"/>
                        <Separator Background="#444" Margin="0,4"/>
                        <Button Content="⚙ Settings" Padding="6,4"
                                Command="{Binding OpenSettingsCommand}"
                                Style="{StaticResource ActionButton}"/>
                    </StackPanel>
                </Border>

                <ListBox x:Name="ListsListBox"
                         ItemsSource="{Binding Lists}"
                         SelectedItem="{Binding SelectedList}"
                         AllowDrop="True"
                         Padding="4"
                         Drop="ListsListBox_Drop">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Name}" Padding="4,3"
                                       TextTrimming="CharacterEllipsis"/>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Foreground" Value="#CCC"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border Background="{TemplateBinding Background}"
                                                CornerRadius="3" Margin="0,1">
                                            <ContentPresenter Margin="2"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#094771"/>
                                    <Setter Property="Foreground" Value="White"/>
                                </Trigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#2A2D2E"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </ListBox.ItemContainerStyle>
                </ListBox>
            </DockPanel>

            <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch" Background="#333"/>

            <!-- PANEL 2: Channels -->
            <DockPanel Grid.Column="2">
                <Border DockPanel.Dock="Top" Background="#252526" Padding="10,8">
                    <TextBlock Text="CHANNELS" FontWeight="Bold" FontSize="11" Foreground="#888"/>
                </Border>

                <Border DockPanel.Dock="Bottom" Background="#252526" Padding="6">
                    <StackPanel>
                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" Margin="0,0,4,0"
                                     Text="{Binding AddChannelText, UpdateSourceTrigger=PropertyChanged}"
                                     ToolTip="Channel URL or @handle"/>
                            <Button Grid.Column="1" Content="Add" Width="40" Padding="4,4"
                                    Command="{Binding AddChannelCommand}"
                                    Style="{StaticResource ActionButton}"/>
                        </Grid>
                        <Button Content="Remove Channel" Padding="6,4"
                                Command="{Binding RemoveChannelCommand}"
                                Style="{StaticResource DangerButton}"/>
                    </StackPanel>
                </Border>

                <ListBox x:Name="ChannelListBox"
                         ItemsSource="{Binding Channels}"
                         SelectedItem="{Binding SelectedChannel}"
                         AllowDrop="True"
                         Padding="4"
                         PreviewMouseLeftButtonDown="ChannelListBox_PreviewMouseLeftButtonDown"
                         PreviewMouseMove="ChannelListBox_PreviewMouseMove"
                         Drop="ChannelListBox_Drop">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding DisplayName}" Padding="4,3"
                                       TextTrimming="CharacterEllipsis"/>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Foreground" Value="#CCC"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border Background="{TemplateBinding Background}"
                                                CornerRadius="3" Margin="0,1">
                                            <ContentPresenter Margin="2"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#094771"/>
                                    <Setter Property="Foreground" Value="White"/>
                                </Trigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#2A2D2E"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </ListBox.ItemContainerStyle>
                </ListBox>
            </DockPanel>

            <GridSplitter Grid.Column="3" Width="5" HorizontalAlignment="Stretch" Background="#333"/>

            <!-- PANEL 3: Videos -->
            <DockPanel Grid.Column="4">
                <Border DockPanel.Dock="Top" Background="#252526" Padding="10,7">
                    <DockPanel LastChildFill="False">
                        <TextBlock Text="VIDEOS" FontWeight="Bold" FontSize="11"
                                   Foreground="#888" VerticalAlignment="Center"/>
                        <Button DockPanel.Dock="Right" Content="↻ Refresh"
                                Command="{Binding RefreshCommand}"
                                Style="{StaticResource PrimaryButton}"
                                Padding="10,3" Margin="6,0,0,0"/>
                        <Button DockPanel.Dock="Right" Content="⟳ Sync Watch History"
                                Command="{Binding SyncWatchHistoryCommand}"
                                Style="{StaticResource ActionButton}"
                                Padding="10,3" Margin="6,0,0,0"/>
                        <Button DockPanel.Dock="Right" Content="📂 Import Takeout"
                                Command="{Binding ImportTakeoutCommand}"
                                Style="{StaticResource ActionButton}"
                                Padding="10,3" Margin="6,0,0,0"/>
                        <Button DockPanel.Dock="Right" Content="Mark All Watched"
                                Command="{Binding MarkAllWatchedCommand}"
                                Style="{StaticResource WatchedButton}"
                                Padding="10,3" Margin="6,0,0,0"/>
                        <CheckBox DockPanel.Dock="Right" Content="Show Watched"
                                  IsChecked="{Binding ShowWatched}"
                                  VerticalAlignment="Center"
                                  Foreground="#AAA" Margin="6,0,0,0"/>
                    </DockPanel>
                </Border>

                <TextBlock DockPanel.Dock="Top" Padding="12,8"
                           Foreground="#555" FontStyle="Italic"
                           Text="Select a list and click Refresh to load videos."
                           Visibility="{Binding HasNoVideos, Converter={StaticResource BoolToVisibility}}"/>

                <ScrollViewer VerticalScrollBarVisibility="Auto" Background="#1E1E1E">
                    <ItemsControl ItemsSource="{Binding Videos}" Padding="8,8,8,4">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#252526" Margin="0,0,0,6" CornerRadius="4"
                                        BorderBrush="#3A3A3A" BorderThickness="1">
                                    <Grid Margin="8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Thumbnail -->
                                        <Border Grid.Column="0" Margin="0,0,10,0"
                                                VerticalAlignment="Center" CornerRadius="3">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Width" Value="88"/>
                                                    <Setter Property="Height" Value="50"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsShort}" Value="True">
                                                            <Setter Property="Width" Value="32"/>
                                                            <Setter Property="Height" Value="57"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <Border.Background>
                                                <ImageBrush ImageSource="{Binding ThumbnailUrl}"
                                                            Stretch="UniformToFill"/>
                                            </Border.Background>
                                        </Border>

                                        <!-- Title + meta -->
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock>
                                                <Hyperlink Command="{Binding OpenInBrowserCommand}"
                                                           Foreground="#4FC3F7"
                                                           TextDecorations="None">
                                                    <TextBlock Text="{Binding DisplayTitle}"
                                                               TextWrapping="Wrap"
                                                               FontSize="13"/>
                                                </Hyperlink>
                                            </TextBlock>
                                            <TextBlock Foreground="#777" FontSize="11" Margin="0,3,0,0">
                                                <Run Text="{Binding ChannelName, Mode=OneWay}"/>
                                                <Run Text=" · "/>
                                                <Run Text="{Binding PublishedAt, Mode=OneWay, StringFormat='MMM d, yyyy'}"/>
                                            </TextBlock>
                                        </StackPanel>

                                        <!-- Action buttons -->
                                        <StackPanel Grid.Column="2" Orientation="Horizontal"
                                                    VerticalAlignment="Center" Margin="10,0,0,0">
                                            <Button Content="★" Margin="0,0,4,0" Padding="6,2"
                                                    Command="{Binding ToggleStarCommand}"
                                                    ToolTip="Toggle star">
                                                <Button.Style>
                                                    <Style TargetType="Button" BasedOn="{StaticResource StarButton}">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsStarred}" Value="True">
                                                                <Setter Property="Foreground" Value="#FFD700"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Button.Style>
                                            </Button>
                                            <Button Content="Watched" Margin="0,0,4,0" Padding="8,4"
                                                    Command="{Binding MarkWatchedCommand}"
                                                    ToolTip="Mark as watched">
                                                <Button.Style>
                                                    <Style TargetType="Button" BasedOn="{StaticResource WatchedButton}">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Status}" Value="Watched">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Button.Style>
                                            </Button>
                                            <Button Content="↩ Unwatched" Margin="0,0,4,0" Padding="8,4"
                                                    Command="{Binding MarkUnwatchedCommand}"
                                                    ToolTip="Mark as unwatched">
                                                <Button.Style>
                                                    <Style TargetType="Button" BasedOn="{StaticResource ActionButton}">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Status}" Value="Watched">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Button.Style>
                                            </Button>
                                            <Button Content="Skip" Margin="0,0,4,0" Padding="8,4"
                                                    Command="{Binding MarkDontWatchCommand}"
                                                    Style="{StaticResource SkipButton}"
                                                    ToolTip="Don't watch this"/>
                                            <Button Content="✕" Padding="8,4"
                                                    Command="{Binding MarkNotInterestedCommand}"
                                                    Style="{StaticResource DangerButton}"
                                                    ToolTip="Not interested"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </DockPanel>
        </Grid>
    </DockPanel>
</Window>

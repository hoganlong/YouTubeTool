<Window x:Class="YouTubeTool.Views.InputDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Input" Height="130" Width="360"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <StackPanel Margin="16">
        <TextBlock x:Name="PromptText" Text="Enter value:" Margin="0,0,0,8"/>
        <TextBox x:Name="InputBox" Margin="0,0,0,12" KeyDown="InputBox_KeyDown"/>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="OK" Width="72" Margin="0,0,8,0" Click="Ok_Click" IsDefault="True"/>
            <Button Content="Cancel" Width="72" Click="Cancel_Click" IsCancel="True"/>
        </StackPanel>
    </StackPanel>
</Window>

<Window x:Class="YouTubeTool.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:YouTubeTool.Converters"
        Title="Settings" Height="520" Width="520"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Window.Resources>
        <conv:TestResultColorConverter x:Key="TestResultColorConverter"/>
    </Window.Resources>
    <ScrollViewer VerticalScrollBarVisibility="Auto">
    <StackPanel Margin="20">

        <!-- API Key -->
        <TextBlock Text="YouTube Data API v3 Key" FontWeight="Bold" Margin="0,0,0,4"/>
        <TextBlock TextWrapping="Wrap" Foreground="Gray" Margin="0,0,0,6"
                   Text="Used to fetch channel video lists. Get one at console.cloud.google.com → APIs &amp; Services → Credentials → Create Credentials → API Key."/>
        <Grid Margin="0,0,0,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <PasswordBox x:Name="ApiKeyBox" Grid.Column="0" Margin="0,0,8,0"
                         PasswordChanged="ApiKeyBox_PasswordChanged"/>
            <Button Grid.Column="1" Content="Test Key" Width="80"
                    Command="{Binding TestApiKeyCommand}"/>
        </Grid>
        <TextBlock Text="{Binding TestResult}" Margin="0,0,0,12"
                   Foreground="{Binding TestResult, Converter={StaticResource TestResultColorConverter}}"/>

        <Separator Margin="0,0,0,12"/>

        <!-- OAuth -->
        <TextBlock Text="Google Account (for Watch History Sync)" FontWeight="Bold" Margin="0,0,0,4"/>
        <TextBlock TextWrapping="Wrap" Foreground="Gray" Margin="0,0,0,6">
            <Run Text="Required to sync your YouTube watch history. In Google Cloud Console, go to APIs &amp; Services → Credentials → Create Credentials → OAuth 2.0 Client ID. Choose "/>
            <Run Text="Desktop app" FontStyle="Italic"/>
            <Run Text=" as the type."/>
        </TextBlock>

        <TextBlock Text="OAuth Client ID" Margin="0,0,0,2"/>
        <TextBox Text="{Binding OAuthClientId, UpdateSourceTrigger=PropertyChanged}"
                 Margin="0,0,0,8"/>

        <TextBlock Text="OAuth Client Secret" Margin="0,0,0,2"/>
        <PasswordBox x:Name="ClientSecretBox" Margin="0,0,0,10"
                     PasswordChanged="ClientSecretBox_PasswordChanged"/>

        <Grid Margin="0,0,0,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0"
                       Text="{Binding SignInStatus}"
                       Foreground="{Binding SignInStatus, Converter={StaticResource TestResultColorConverter}}"
                       VerticalAlignment="Center"/>
            <Button Grid.Column="1" Content="Sign In" Width="80" Margin="0,0,8,0"
                    Command="{Binding SignInCommand}"/>
            <Button Grid.Column="2" Content="Sign Out" Width="80"
                    Command="{Binding SignOutCommand}"/>
        </Grid>

        <Separator Margin="0,12,0,12"/>

        <!-- YouTube Browser Session -->
        <TextBlock Text="YouTube Browser Session" FontWeight="Bold" Margin="0,0,0,4"/>
        <TextBlock TextWrapping="Wrap" Foreground="Gray" Margin="0,0,0,8"
                   Text="Used for Watch History Sync and Load Subscriptions. Use 'Switch Account' to sign in as a different Google account right now."/>
        <Grid Margin="0,0,0,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="{Binding YouTubeSessionStatus}"
                       Foreground="{Binding YouTubeSessionStatus, Converter={StaticResource TestResultColorConverter}}"
                       VerticalAlignment="Center"/>
            <Button Grid.Column="1" Content="Switch Account" Width="115" Margin="0,0,6,0"
                    Click="SwitchAccount_Click"/>
            <Button Grid.Column="2" Content="Clear Session" Width="100"
                    Command="{Binding ClearYouTubeSessionCommand}"/>
        </Grid>

        <Separator Margin="0,12,0,12"/>

        <!-- Other settings -->
        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
            <TextBlock Text="Max videos per channel:" VerticalAlignment="Center" Margin="0,0,8,0"/>
            <TextBox Width="60" Text="{Binding MaxVideos}"/>
        </StackPanel>

        <!-- UI Scale -->
        <TextBlock Text="UI Scale" FontWeight="Bold" Margin="0,0,0,4"/>
        <Grid Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="44"/>
            </Grid.ColumnDefinitions>
            <Slider Grid.Column="0"
                    Minimum="0.7" Maximum="1.5"
                    SmallChange="0.05" LargeChange="0.1"
                    TickFrequency="0.05" IsSnapToTickEnabled="True"
                    VerticalAlignment="Center"
                    Value="{Binding UiScale}"/>
            <TextBlock Grid.Column="1"
                       Text="{Binding UiScale, StringFormat='{}{0:P0}'}"
                       HorizontalAlignment="Right" VerticalAlignment="Center"/>
        </Grid>

        <Button Content="Save" HorizontalAlignment="Right"
                Width="80" Command="{Binding SaveCommand}"/>

    </StackPanel>
    </ScrollViewer>
</Window>

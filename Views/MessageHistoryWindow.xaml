<Window x:Class="YouTubeTool.Views.MessageHistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Message History" Height="400" Width="660"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="#1E1E1E">
    <DockPanel x:Name="RootPanel" Margin="10">
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button Content="Copy Selected" Width="110" Padding="6,4" Margin="0,0,8,0"
                    Click="CopySelected_Click"
                    Background="#0E639C" Foreground="White" BorderThickness="0" Cursor="Hand"/>
            <Button Content="Copy All" Width="90" Padding="6,4" Margin="0,0,8,0"
                    Click="CopyAll_Click"
                    Background="#0E639C" Foreground="White" BorderThickness="0" Cursor="Hand"/>
            <Button Content="Close" Width="70" Padding="6,4"
                    Click="Close_Click"
                    Background="#444" Foreground="White" BorderThickness="0" Cursor="Hand"/>
        </StackPanel>
        <ListBox x:Name="MessageList"
                 Background="#252526" BorderBrush="#444" BorderThickness="1"
                 Foreground="#DDD" FontFamily="Consolas" FontSize="12" Padding="4"
                 SelectionMode="Extended"
                 ScrollViewer.HorizontalScrollBarVisibility="Auto">
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="Padding" Value="4,2"/>
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="BorderThickness" Value="0"/>
                    <Style.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="#094771"/>
                            <Setter Property="Foreground" Value="White"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#2A2D2E"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </ListBox.ItemContainerStyle>
        </ListBox>
    </DockPanel>
</Window>

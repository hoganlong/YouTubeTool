<Window x:Class="YouTubeTool.Views.YouTubeLoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="Connect to YouTube" Height="700" Width="500"
        WindowStartupLocation="CenterOwner">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Padding="12,10"
                   Text="Sign into YouTube below. When done, click the button."
                   Background="#1E1E1E" Foreground="White" FontSize="13"/>

        <wv2:WebView2 x:Name="WebView" Grid.Row="1"/>

        <Button Grid.Row="2" Content="Done — I'm logged in"
                Margin="12" Padding="0,10"
                FontSize="14" FontWeight="SemiBold"
                Background="#007ACC" Foreground="White" BorderThickness="0"
                Cursor="Hand" Click="Done_Click"/>
    </Grid>
</Window>

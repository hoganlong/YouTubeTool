<Window x:Class="YouTubeTool.Views.ErrorDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Unhandled Error" Height="420" Width="620"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize">
    <DockPanel Margin="12">
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="Copy to Clipboard" Width="140" Margin="0,0,8,0"
                    Padding="6,4" Click="Copy_Click"/>
            <Button Content="Exit Application" Width="130"
                    Padding="6,4" Click="Exit_Click"
                    Background="#c0392b" Foreground="White"/>
        </StackPanel>
        <TextBox x:Name="ErrorText"
                 IsReadOnly="True"
                 TextWrapping="Wrap"
                 VerticalScrollBarVisibility="Auto"
                 HorizontalScrollBarVisibility="Auto"
                 FontFamily="Consolas" FontSize="12"
                 Background="#1e1e1e" Foreground="#f8f8f2"
                 BorderThickness="1" BorderBrush="#555"
                 Padding="8"/>
    </DockPanel>
</Window>
